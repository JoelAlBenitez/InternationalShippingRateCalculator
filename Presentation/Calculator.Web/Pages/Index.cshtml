@page
@model IndexModel
@{
    ViewData["Title"] = "Calculadora de Tarifas de Envío Internacional";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">Calculadora de Tarifas de Envío</h2>
                </div>
                <div class="card-body p-5">
                    <form id="tariffForm">
                        <div class="form-group mb-4">
                            <label for="countryId" class="form-label fw-bold">País de Destino <span class="text-danger">*</span></label>
                            <select class="form-select form-select-lg" id="countryId" name="countryId" required aria-label="Seleccione un país">
                                <option value="">-- Seleccione un país --</option>
                                <option value="1">India - $5.00 USD/kg</option>
                                <option value="2">US - $8.00 USD/kg</option>
                                <option value="3">UK - $10.00 USD/kg</option>
                            </select>
                            <div class="invalid-feedback d-block" id="countryError"></div>
                        </div>

                        <div class="form-group mb-4">
                            <label for="weight" class="form-label fw-bold">Peso del Envío (kg) <span class="text-danger">*</span></label>
                            <input type="number" 
                                   class="form-control form-control-lg" 
                                   id="weight" 
                                   name="weight" 
                                   placeholder="Ingrese el peso en kilogramos"
                                   step="0.01"
                                   min="0.01"
                                   max="70"
                                   required
                                   aria-label="Peso del envío en kilogramos">
                            <small class="form-text text-muted d-block mt-2">Peso máximo permitido: 70 kg</small>
                            <div class="invalid-feedback d-block" id="weightError"></div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold mb-3">
                            <i class="bi bi-calculator"></i> Calcular Tarifa
                        </button>
                    </form>

                    <div id="resultContainer" class="d-none mt-5">
                        <div class="alert alert-success" role="alert">
                            <h4 class="alert-heading">¡Cálculo exitoso!</h4>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>País:</strong> <span id="resultCountry"></span></p>
                                <p><strong>Peso:</strong> <span id="resultWeight"></span> kg</p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Tarifa por kg:</strong> $<span id="resultTariffPerKg"></span></p>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-12">
                                <div class="bg-light p-4 border border-success rounded">
                                    <h5 class="text-muted">Costo Total</h5>
                                    <h2 class="text-success fw-bold">$<span id="resultTotal"></span> USD</h2>
                                </div>
                            </div>
                        </div>
                        <button type="button" class="btn btn-secondary mt-4 w-100" onclick="resetForm()">
                            Calcular otro envío
                        </button>
                    </div>

                    <div id="errorContainer" class="d-none mt-5">
                        <div class="alert alert-danger" role="alert">
                            <h4 class="alert-heading">Error en el cálculo</h4>
                            <p id="errorMessage"></p>
                        </div>
                        <button type="button" class="btn btn-secondary w-100" onclick="resetForm()">
                            Volver a intentar
                        </button>
                    </div>

                    <div id="loadingContainer" class="d-none mt-5 text-center">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Calculando...</span>
                        </div>
                        <p class="mt-3 text-muted">Calculando tarifa...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/js/calculator.js"></script>
